<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="#C85A2C">
    <meta name="description" content="Learn Indonesian with interactive lessons, cultural context, and practical phrases">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Bahasa">
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'><rect fill='%23C85A2C' width='180' height='180' rx='40'/><text x='90' y='90' font-size='100' font-weight='bold' fill='white' text-anchor='middle' dominant-baseline='middle' font-family='system-ui'>BI</text></svg>">
    <link rel="manifest" href="./manifest.json">
    <title>Bahasa Indonesian Guide</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-warm: #C85A2C;
            --primary-dark: #8B4513;
            --accent-green: #2D7A4A;
            --accent-gold: #D4AF37;
            --cream: #F5F2ED;
            --text-dark: #2C2C2C;
            --text-light: #666;
            --border-soft: #E8DED3;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--cream) 0%, #FAF7F2 100%);
            color: var(--text-dark);
            line-height: 1.6;
            min-height: 100vh;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* Header & Hero */
        .hero {
            text-align: center;
            margin-bottom: 3rem;
            padding: 2rem;
            background: linear-gradient(135deg, var(--primary-warm) 0%, var(--primary-dark) 100%);
            color: white;
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(200, 90, 44, 0.15);
        }

        .hero h1 {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .hero p {
            font-size: 1.1rem;
            opacity: 0.95;
            max-width: 600px;
            margin: 0 auto;
        }

        .progress-bar {
            margin-top: 1.5rem;
            background: rgba(255, 255, 255, 0.2);
            height: 8px;
            border-radius: 4px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: var(--accent-gold);
            width: 0%;
            transition: width 0.3s ease;
        }

        .progress-text {
            margin-top: 0.5rem;
            font-size: 0.95rem;
            opacity: 0.9;
        }

        /* Lessons */
        .lessons-grid {
            display: grid;
            gap: 1.5rem;
        }

        .lesson {
            background: white;
            border-left: 4px solid var(--primary-warm);
            padding: 1.5rem;
            border-radius: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .lesson:hover {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
            transform: translateY(-2px);
        }

        .lesson.completed {
            background: linear-gradient(to right, rgba(45, 122, 74, 0.05), transparent);
            border-left-color: var(--accent-green);
        }

        .lesson-header {
            display: flex;
            align-items: center;
            margin-bottom: 1.5rem;
            gap: 1rem;
        }

        .lesson-number {
            width: 40px;
            height: 40px;
            background: var(--primary-warm);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .lesson.completed .lesson-number {
            background: var(--accent-green);
        }

        .lesson-title {
            flex: 1;
        }

        .lesson-title h2 {
            font-size: 1.4rem;
            margin-bottom: 0.25rem;
            color: var(--text-dark);
        }

        .lesson-title .theme {
            font-size: 0.85rem;
            color: var(--accent-gold);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        .lesson-content {
            margin-bottom: 1.5rem;
        }

        .content-section {
            margin-bottom: 1.5rem;
        }

        .content-section h3 {
            font-size: 1.1rem;
            color: var(--primary-dark);
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .section-icon {
            width: 24px;
            height: 24px;
            background: var(--accent-gold);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
        }

        .phrase-item, .grammar-item, .cultural-item {
            background: var(--cream);
            padding: 1rem;
            border-radius: 6px;
            margin-bottom: 0.75rem;
            border-left: 3px solid var(--border-soft);
        }

        .phrase-item {
            border-left-color: var(--primary-warm);
        }

        .grammar-item {
            border-left-color: var(--accent-green);
        }

        .cultural-item {
            border-left-color: var(--accent-gold);
        }

        .phrase-item strong, .grammar-item strong, .cultural-item strong {
            display: block;
            font-size: 1.05rem;
            margin-bottom: 0.25rem;
        }

        .pronunciation {
            font-style: italic;
            font-size: 0.9rem;
            color: var(--text-light);
            margin: 0.25rem 0;
        }

        .translation {
            font-size: 0.95rem;
            color: var(--text-dark);
            margin: 0.5rem 0 0 0;
        }

        /* Checkboxes */
        .lesson-checklist {
            display: grid;
            gap: 0.75rem;
            padding: 1.25rem;
            background: linear-gradient(to right, rgba(200, 90, 44, 0.03), transparent);
            border-radius: 6px;
            margin-top: 1rem;
            border: 1px solid var(--border-soft);
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.95rem;
        }

        .checkbox-item input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: var(--accent-green);
            flex-shrink: 0;
        }

        .checkbox-item label {
            cursor: pointer;
            flex: 1;
            user-select: none;
        }

        .checkbox-item input[type="checkbox"]:checked + label {
            color: var(--accent-green);
            font-weight: 500;
        }

        /* Footer */
        .footer {
            text-align: center;
            margin-top: 4rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border-soft);
            color: var(--text-light);
            font-size: 0.9rem;
        }

        .footer p {
            margin: 0.5rem 0;
        }

        /* Responsive */
        @media (max-width: 640px) {
            .hero h1 {
                font-size: 1.75rem;
            }

            .hero p {
                font-size: 1rem;
            }

            .container {
                padding: 1rem;
            }

            .lesson-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .lesson-number {
                width: 32px;
                height: 32px;
                font-size: 0.9rem;
            }

            .lesson-title h2 {
                font-size: 1.2rem;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            * {
                transition: none !important;
                animation: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="hero">
            <h1>Bahasa Indonesia</h1>
            <p>Learn Indonesian through practical phrases, essential grammar, and cultural insights. Your journey from Jakarta to fluency starts here.</p>
            <div class="progress-bar">
                <div class="progress-fill"></div>
            </div>
            <div class="progress-text">
                <span id="completed">0</span> of <span id="total">0</span> checkpoints mastered
            </div>
        </div>

        <div class="lessons-grid" id="lessonsContainer"></div>

        <div class="footer">
            <p><strong>💡 Tip:</strong> Check off concepts as you learn them. Your progress saves automatically.</p>
            <p>Selamat belajar! (Happy learning!)</p>
            <button onclick="resetProgress()" style="margin-top: 1rem; padding: 0.75rem 1.5rem; background: var(--primary-warm); color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 0.9rem;">Reset Progress</button>
        </div>
    </div>

    <script>
        const lessonsData = [
            {
                id: 1,
                title: "Meeting & Greetings",
                theme: "Foundation",
                phrases: [
                    { text: "Halo", pronunciation: "HAH-lo", translation: "Hello" },
                    { text: "Selamat pagi", pronunciation: "suh-LAH-mat PAH-gee", translation: "Good morning" },
                    { text: "Apa kabar?", pronunciation: "AH-pa KAH-bar", translation: "How are you?" },
                    { text: "Baik-baik saja", pronunciation: "bah-EEK bah-EEK SAH-ja", translation: "I'm fine" },
                    { text: "Nama saya...", pronunciation: "NAH-ma SAH-ya", translation: "My name is..." }
                ],
                grammar: [
                    { text: "Personal Pronouns", rule: "Saya (I), Anda (you formal), Dia (he/she), Kami (we), Mereka (they)" }
                ],
                cultural: [
                    { text: "Handshake etiquette", insight: "In Indonesian culture, a firm handshake is respectful. When meeting elders, it's polite to wait for them to extend their hand first. In Jakarta's business culture, this matters—respect for hierarchy is embedded in greetings." }
                ],
                checkpoints: [
                    "Master 5 basic greetings",
                    "Pronounce personal pronouns",
                    "Understand greeting etiquette"
                ]
            },
            {
                id: 2,
                title: "Everyday Conversation",
                theme: "Practical",
                phrases: [
                    { text: "Berapa harga?", pronunciation: "buh-RAH-pa HAR-ga", translation: "How much does it cost?" },
                    { text: "Terima kasih", pronunciation: "tuh-REE-ma KAH-see", translation: "Thank you" },
                    { text: "Tidak, terima kasih", pronunciation: "tee-AHK, tuh-REE-ma KAH-see", translation: "No, thank you" },
                    { text: "Maaf, bisa membantu?", pronunciation: "mah-AHF, BEE-sa mem-BAHN-too", translation: "Excuse me, can you help?" },
                    { text: "Kemana jalan ke...?", pronunciation: "kuh-MAH-na JAH-lan kuh", translation: "Where is the way to...?" }
                ],
                grammar: [
                    { text: "Question words", rule: "Berapa (how much), Apa (what), Mana (which), Siapa (who), Kapan (when)" },
                    { text: "Polite requests", rule: "Use 'bisa' (can) + verb to ask politely. Example: 'Bisa membantu?' (Can help?)" }
                ],
                cultural: [
                    { text: "Market culture", insight: "In Indonesian markets (pasar), bargaining is expected and is a social ritual. Haggling isn't aggressive—it's friendly negotiation. In Surabaya's famous fish market, starting at 70% of the asking price is normal." },
                    { text: "Politeness matters", insight: "Always use 'terima kasih' (thank you). Indonesians value gratitude highly. Even small transactions deserve thanks." }
                ],
                checkpoints: [
                    "Ask prices confidently",
                    "Use polite request structures",
                    "Understand haggling context"
                ]
            },
            {
                id: 3,
                title: "Food & Dining",
                theme: "Cultural",
                phrases: [
                    { text: "Makanan apa yang enak?", pronunciation: "mah-KAH-nan AH-pa yang AY-nak", translation: "What food tastes good?" },
                    { text: "Saya suka makanan pedas", pronunciation: "SAH-ya SOO-ka mah-KAH-nan puh-DAHS", translation: "I like spicy food" },
                    { text: "Kopi atau teh?", pronunciation: "KO-pee AH-too tay", translation: "Coffee or tea?" },
                    { text: "Nasi goreng, silakan", pronunciation: "NAH-see GO-reng, see-LAH-kan", translation: "Fried rice, please" },
                    { text: "Ini enak sekali!", pronunciation: "EE-nee AY-nak suh-KAH-lee", translation: "This is delicious!" }
                ],
                grammar: [
                    { text: "Adjectives + nouns", rule: "Place adjectives after nouns: 'makanan pedas' (spicy food), 'teh panas' (hot tea)" },
                    { text: "Preferences with 'suka'", rule: "'Suka' means 'like'. Structure: Saya suka [noun/activity]. 'Saya suka kopi' = I like coffee." }
                ],
                cultural: [
                    { text: "Indonesian staples", insight: "Rice (nasi) is the foundation of every meal. Nasi goreng (fried rice) and gado-gado (vegetable medley) are national favorites. Understanding food is understanding Indonesia." },
                    { text: "Shared meals", insight: "Indonesians eat communally. When offered food, accepting builds relationships. Declining repeatedly is seen as impolite. In Bali especially, sharing meals is sacred." },
                    { text: "Street food scene", insight: "Warung (small restaurants) and street food vendors are where locals eat. Trying street food—sate, lumpia, martabak—is how you experience authentic Indonesia." }
                ],
                checkpoints: [
                    "Order 3 common dishes",
                    "Express food preferences",
                    "Understand dining etiquette"
                ]
            },
            {
                id: 4,
                title: "Getting Around",
                theme: "Practical",
                phrases: [
                    { text: "Stasiun kereta mana?", pronunciation: "stah-see-OON kuh-RAY-ta MAH-na", translation: "Where is the train station?" },
                    { text: "Taksi, sini!", pronunciation: "TAHK-see, SEE-nee", translation: "Taxi, over here!" },
                    { text: "Berapa jarak ke pusat kota?", pronunciation: "buh-RAH-pa JAH-rak kuh POO-sat KO-ta", translation: "How far to the city center?" },
                    { text: "Jalan ini ke mall?", pronunciation: "JAH-lan EE-nee kuh mall", translation: "Does this road go to the mall?" },
                    { text: "Turun di sini, terima kasih", pronunciation: "TOO-roon dee SEE-nee, tuh-REE-ma KAH-see", translation: "Drop me here, thank you" }
                ],
                grammar: [
                    { text: "Direction verbs", rule: "'Ke' (to), 'dari' (from), 'di' (at). Example: 'Jalan ke stasiun' (walk to the station)" },
                    { text: "Question formation", rule: "For location: '[Place] mana?' For distance: 'Berapa jarak ke [place]?'" }
                ],
                cultural: [
                    { text: "Jakarta traffic", insight: "Traffic in Jakarta is intense. Taking a taxi or Gojek (motorcycle taxi) is common. Knowing how to negotiate directions saves frustration." },
                    { text: "Public transport", insight: "Indonesia's public transportation is affordable. Buses, trains, and ferries connect cities. Bali's Kuta Beach is reachable by cheap buses from the airport." },
                    { text: "Navigation rituals", insight: "Always ask locals for directions—they love helping. Landmarks matter more than street names. 'Near the red warung' is better than an address." }
                ],
                checkpoints: [
                    "Ask for directions",
                    "Understand transport options",
                    "Communicate with drivers"
                ]
            },
            {
                id: 5,
                title: "Daily Life & Routines",
                theme: "Intermediate",
                phrases: [
                    { text: "Saya bekerja di Jakarta", pronunciation: "SAH-ya buh-KER-ja dee JAH-kar-ta", translation: "I work in Jakarta" },
                    { text: "Hari Senin saya sibuk", pronunciation: "HAH-ree SUN-een SAH-ya see-BOOK", translation: "On Monday I'm busy" },
                    { text: "Jam berapa Anda bangun?", pronunciation: "jam buh-RAH-pa AHN-da BAHN-gun", translation: "What time do you wake up?" },
                    { text: "Saya tidur jam 11", pronunciation: "SAH-ya TEE-doo-r jam se-buh-LAS", translation: "I sleep at 11" },
                    { text: "Apa yang Anda lakukan hari ini?", pronunciation: "AH-pa yang AHN-da lah-KOO-kan HAH-ree EE-nee", translation: "What are you doing today?" }
                ],
                grammar: [
                    { text: "Time telling", rule: "'Jam' = clock/time. 'Jam tiga' = 3 o'clock. 'Jam berapa?' = What time?" },
                    { text: "Days & routine verbs", rule: "Days: Senin (Monday) through Minggu (Sunday). Verbs: bangun (wake), bekerja (work), tidur (sleep), makan (eat)" }
                ],
                cultural: [
                    { text: "Work culture", insight: "Indonesian work culture emphasizes relationships first, tasks second. Building rapport (silaturahim) is more important than punctuality. Coffee breaks are social rituals." },
                    { text: "Time perception", insight: "Indonesians have a relaxed approach to time called 'jam karet' (rubber time). Things start when people arrive, not by the clock. Adjust expectations accordingly." },
                    { text: "Family & routines", insight: "Family is central. Weekend routines often involve visiting extended family. Sunday afternoons in Jakarta, families gather for 'soto ayam' (chicken soup) and conversation." }
                ],
                checkpoints: [
                    "Tell time accurately",
                    "Describe your routine",
                    "Ask about others' daily life"
                ]
            },
            {
                id: 6,
                title: "Cultural Insights & Deeper Connections",
                theme: "Cultural",
                phrases: [
                    { text: "Merdeka!", pronunciation: "mer-DAY-ka", translation: "Freedom! (Indonesian independence cry)" },
                    { text: "Gotong royong", pronunciation: "GO-tong ro-YONG", translation: "Mutual cooperation (core Indonesian value)" },
                    { text: "Bhinneka Tunggal Ika", pronunciation: "been-NAY-ka TOONG-gal EE-ka", translation: "Unity in Diversity (Indonesia's motto)" },
                    { text: "Saya bangga menjadi Indonesia", pronunciation: "SAH-ya BAHN-ga men-JAH-dee In-do-NAY-see-a", translation: "I'm proud to be Indonesian" },
                    { text: "Terima kasih Indonesia", pronunciation: "tuh-REE-ma KAH-see In-do-NAY-see-a", translation: "Thank you, Indonesia" }
                ],
                grammar: [
                    { text: "Connecting phrases", rule: "'Karena' (because), 'tapi' (but), 'dan' (and), 'atau' (or) link ideas. Use to express why you appreciate Indonesian culture." }
                ],
                cultural: [
                    { text: "Pancasila philosophy", insight: "Indonesia's founding principle balances unity, diversity, and democracy. Understanding Pancasila helps you understand why Indonesia works despite 700+ languages and religions coexisting peacefully." },
                    { text: "Wayang & arts", insight: "Wayang puppet theater isn't just entertainment—it's philosophy, history, and morality wrapped in shadow and music. Attending a wayang show (especially in Yogyakarta or Solo) is experiencing Indonesian soul." },
                    { text: "Spiritual syncretism", insight: "Indonesian Islam blends with Hindu, Buddhist, and animist traditions. Visiting temples in Bali or the Grand Mosque in Jakarta shows how Indonesians honor multiple truths. Balinese Hinduism has a unique character—it's not Indian Hinduism transplanted." },
                    { text: "Connection to land", insight: "Indonesians deeply respect their environment. Rice paddies, mountains, seas—each region has spiritual significance. 'Bhinneka Tunggal Ika' celebrates this diversity. Learning Indonesian is learning to see the world through this lens." }
                ],
                checkpoints: [
                    "Understand Indonesian values",
                    "Learn historical phrases",
                    "Appreciate cultural depth"
                ]
            }
        ];

        function initializeLessons() {
            const container = document.getElementById('lessonsContainer');
            container.innerHTML = '';

            lessonsData.forEach(lesson => {
                const lessonEl = document.createElement('div');
                lessonEl.className = 'lesson';
                lessonEl.id = `lesson-${lesson.id}`;

                let phrasesHTML = lesson.phrases.map(p => `
                    <div class="phrase-item">
                        <strong>${p.text}</strong>
                        <div class="pronunciation">${p.pronunciation}</div>
                        <div class="translation">${p.translation}</div>
                    </div>
                `).join('');

                let grammarHTML = lesson.grammar.map(g => `
                    <div class="grammar-item">
                        <strong>${g.text}</strong>
                        <div style="margin-top: 0.5rem;">${g.rule}</div>
                    </div>
                `).join('');

                let culturalHTML = lesson.cultural.map(c => `
                    <div class="cultural-item">
                        <strong>${c.text}</strong>
                        <div style="margin-top: 0.5rem;">${c.insight}</div>
                    </div>
                `).join('');

                let checklistHTML = lesson.checkpoints.map((checkpoint, idx) => `
                    <div class="checkbox-item">
                        <input type="checkbox" id="check-${lesson.id}-${idx}" data-lesson="${lesson.id}">
                        <label for="check-${lesson.id}-${idx}">${checkpoint}</label>
                    </div>
                `).join('');

                lessonEl.innerHTML = `
                    <div class="lesson-header">
                        <div class="lesson-number">${lesson.id}</div>
                        <div class="lesson-title">
                            <h2>${lesson.title}</h2>
                            <div class="theme">${lesson.theme}</div>
                        </div>
                    </div>

                    <div class="lesson-content">
                        <div class="content-section">
                            <h3><span class="section-icon">🗣️</span> Essential Phrases</h3>
                            ${phrasesHTML}
                        </div>

                        <div class="content-section">
                            <h3><span class="section-icon">📖</span> Grammar Essentials</h3>
                            ${grammarHTML}
                        </div>

                        <div class="content-section">
                            <h3><span class="section-icon">🌏</span> Cultural Context</h3>
                            ${culturalHTML}
                        </div>
                    </div>

                    <div class="lesson-checklist">
                        ${checklistHTML}
                    </div>
                `;

                container.appendChild(lessonEl);
            });

            document.getElementById('total').textContent = lessonsData.length * 3;
            loadProgress();
            attachCheckboxListeners();
        }

        function attachCheckboxListeners() {
            document.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
                checkbox.addEventListener('change', saveProgress);
            });
        }

        function saveProgress() {
            const state = [];
            document.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
                state.push({
                    id: checkbox.id,
                    checked: checkbox.checked
                });
            });
            localStorage.setItem('bahasa-progress', JSON.stringify(state));
            updateProgressBar();
        }

        function loadProgress() {
            const saved = localStorage.getItem('bahasa-progress');
            if (saved) {
                const state = JSON.parse(saved);
                state.forEach(item => {
                    const checkbox = document.getElementById(item.id);
                    if (checkbox) {
                        checkbox.checked = item.checked;
                        updateLessonStatus(checkbox.dataset.lesson);
                    }
                });
            }
            updateProgressBar();
        }

        function updateProgressBar() {
            const total = document.querySelectorAll('input[type="checkbox"]').length;
            const checked = document.querySelectorAll('input[type="checkbox"]:checked').length;
            const percentage = (checked / total) * 100;
            
            document.querySelector('.progress-fill').style.width = percentage + '%';
            document.getElementById('completed').textContent = checked;
        }

        function updateLessonStatus(lessonId) {
            const checkboxes = document.querySelectorAll(`input[data-lesson="${lessonId}"]`);
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            const lessonEl = document.getElementById(`lesson-${lessonId}`);
            
            if (allChecked && checkboxes.length > 0) {
                lessonEl.classList.add('completed');
            } else {
                lessonEl.classList.remove('completed');
            }
        }

        function resetProgress() {
            if (confirm('Are you sure? This will erase all your progress.')) {
                localStorage.removeItem('bahasa-progress');
                document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
                document.querySelectorAll('.lesson').forEach(l => l.classList.remove('completed'));
                updateProgressBar();
            }
        }

        // Initialize on load
        document.addEventListener('DOMContentLoaded', initializeLessons);

        // Register service worker for offline support
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('./service-worker.js')
                    .then(reg => console.log('Service Worker registered'))
                    .catch(err => console.log('Service Worker registration failed:', err));
            });
        }
    </script>
</body>
</html>

